#!/bin/bash
# Pre-commit hook for kotlin-spring-harness
# Runs fast checks: detekt + ArchUnit architecture tests
# Does NOT run full test suite or Pitest (too slow for pre-commit)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Track overall status
STATUS=0

# Run Detekt
echo -e "\n${YELLOW}▶ Running Detekt (static analysis)...${NC}"
if ./gradlew detekt --quiet; then
    echo -e "${GREEN}✓ Detekt passed${NC}"
else
    echo -e "${RED}✗ Detekt failed${NC}"
    STATUS=1
fi

# Run ArchUnit architecture tests only
echo -e "\n${YELLOW}▶ Running ArchUnit architecture tests...${NC}"
if ./gradlew test --tests "*ArchitectureTest" --quiet; then
    echo -e "${GREEN}✓ Architecture tests passed${NC}"
else
    echo -e "${RED}✗ Architecture tests failed${NC}"
    STATUS=1
fi

# Final result
echo ""
if [ $STATUS -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}✗ Pre-commit checks failed. Please fix the issues before committing.${NC}"
    echo -e "${YELLOW}Tip: Run './gradlew detekt' or './gradlew test --tests \"*ArchitectureTest\"' to see details.${NC}"
    exit 1
fi
